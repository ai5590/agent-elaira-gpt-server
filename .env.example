# Runtime
SERVER_PORT=7003
SPRING_DATASOURCE_URL=jdbc:sqlite:./data/app.db
LOG_FILE_NAME=./logs/dialogue-api.log
LOG_LEVEL_ROOT=INFO
LOG_LEVEL_CLIENT=INFO
APP_LOGGING_DEBUG_PACKETS=false
