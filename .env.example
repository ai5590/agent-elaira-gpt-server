# API auth
APP_SECURITY_TOKEN=

# OpenAI
APP_OPENAI_API_KEY=
APP_OPENAI_MODEL=gpt-5.4
APP_OPENAI_TRANSCRIPTION_MODEL=whisper-1
APP_OPENAI_BASE_URL=https://api.openai.com
APP_OPENAI_MOCK_ENABLED=false

# Optional Telegram notifications
APP_TELEGRAM_BOT_TOKEN=
